		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^6.1.3",
		"@tailwindcss/postcss": "^4.1.12",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/eslint": "^9.6.1",
